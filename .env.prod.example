# ============================================
# AgriSense Production Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Server
PORT=8080
ENV=production
JWT_SECRET=change-this-to-a-random-64-char-string

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=agrisense
DB_PASSWORD=change-this-to-a-strong-password
DB_NAME=agrisense
DB_SSL_MODE=disable

# InfluxDB (app connection)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=change-this-to-a-strong-token
INFLUXDB_ORG=agrisense
INFLUXDB_BUCKET=sensor_data

# InfluxDB (init - only used by influxdb container)
INFLUXDB_USER=agrisense
INFLUXDB_PASSWORD=change-this-to-a-strong-influx-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-to-a-strong-redis-password
REDIS_DB=0

# MQTT
MQTT_BROKER=tcp://emqx:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Grafana
GRAFANA_ADMIN_PASSWORD=change-this-to-a-strong-grafana-password
